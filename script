            h.AssemblyLinearVelocity  = Vector3.zero
            h.AssemblyAngularVelocity = Vector3.zero
            h.CFrame = CFrame.new(h.Position.X, math.random(2000, 999999), h.Position.Z)
            task.wait(0.01)
