local tabs = {}
local activeTabBtn = nil

local function selectTab(tabName, tabBtn, color)
    if activeTabBtn then
        TweenService:Create(activeTabBtn, TweenInfo.new(0.35, Enum.EasingStyle.Quad), {
            BackgroundColor3 = Colors.Sidebar
        }):Play()
        local i = activeTabBtn:FindFirstChildOfClass("ImageLabel")
        local l = activeTabBtn:FindFirstChildOfClass("TextLabel")
        if i then TweenService:Create(i, TweenInfo.new(0.35), {ImageColor3 = Colors.TextDim}):Play() end
        if l then TweenService:Create(l, TweenInfo.new(0.35), {TextColor3 = Colors.TextDim}):Play() end
    end

    TweenService:Create(tabBtn, TweenInfo.new(0.35, Enum.EasingStyle.Quad), {
        BackgroundColor3 = Colors.TabSelected
    }):Play()
    local i = tabBtn:FindFirstChildOfClass("ImageLabel")
    local l = tabBtn:FindFirstChildOfClass("TextLabel")
    if i then TweenService:Create(i, TweenInfo.new(0.35), {ImageColor3 = color}):Play() end
    if l then TweenService:Create(l, TweenInfo.new(0.35), {TextColor3 = Colors.Text}):Play() end

    activeTabBtn = tabBtn
end

