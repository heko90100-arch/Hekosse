local RS = game:GetService("ReplicatedStorage")
local CS = game:GetService("CollectionService")

local char, hrp

local function updateChar()
    char = Player.Character or Player.CharacterAdded:Wait()
    hrp = char:WaitForChild("HumanoidRootPart")
end

updateChar()
