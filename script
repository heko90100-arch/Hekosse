        Position = UDim2.new(0.5, -(IsMobile and 340 or 380), 0.5, -(IsMobile and 245 or 255))
    }):Play()
end

local function CloseUI()
    TweenService:Create(MainWin, TweenInfo.new(0.75, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Position = UDim2.new(1.5, 0, 0.5, -(WinSize.Y.Offset/2))
    }):Play()
    task.delay(0.8, function()
        MainWin.Visible = false
    end)
end

